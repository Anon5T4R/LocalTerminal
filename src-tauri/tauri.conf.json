{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalTerminal",
  "version": "0.5.0",
  "identifier": "com.localterminal.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1462",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LocalTerminal",
        "width": 1020,
        "height": 660,
        "minWidth": 560,
        "minHeight": 380
      },
      {
        "label": "quake",
        "title": "LocalTerminal — quake",
        "url": "quake.html",
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "width": 1020,
        "height": 460
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
